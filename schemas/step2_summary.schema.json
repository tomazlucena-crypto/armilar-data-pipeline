{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Armilar ICP 2021 Step 2 summary",
  "type": "object",
  "required": [
    "pipeline_version",
    "reference_year",
    "observed_research_weight_sum",
    "research_release_allowed",
    "global_12_category_matrix_complete",
    "monetary_release_allowed",
    "status",
    "blocking_reasons"
  ],
  "properties": {
    "pipeline_version": {"type": "string"},
    "reference_year": {"const": 2021},
    "observed_research_weight_sum": {"type": "string"},
    "research_release_allowed": {"type": "boolean"},
    "global_12_category_matrix_complete": {"type": "boolean"},
    "monetary_release_allowed": {"const": false},
    "status": {"type": "string"},
    "blocking_reasons": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
