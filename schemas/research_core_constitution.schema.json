{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://armilar.org/schemas/research_core_constitution.schema.json",
  "title": "Armilar Research Core constitution",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "constitution_id", "constitution_version", "constitution_status", "research_core_id", "scope", "economies", "basket_categories", "benchmark_categories", "series", "currency_policy", "release_gates", "pending_decisions", "basket_materialization", "prohibitions", "source_documents"],
  "properties": {
    "schema_version": {"const": "1.1"},
    "constitution_id": {"const": "ARMILAR_RESEARCH_CORE_V1"},
    "constitution_version": {"const": "0.2.0-draft"},
    "constitution_status": {"const": "DRAFT"},
    "research_core_id": {"const": "ARMILAR_RESEARCH_CORE_V1"},
    "scope": {"type": "object"},
    "economies": {"const": ["DEU", "ESP", "FRA", "ITA", "PRT"]},
    "basket_categories": {"const": ["CP01", "CP02", "CP03", "CP04", "CP05", "CP06", "CP07", "CP08", "CP09", "CP10", "CP11", "CP12"]},
    "benchmark_categories": {"const": ["CP00"]},
    "series": {"type": "object"},
    "currency_policy": {"type": "object"},
    "release_gates": {"type": "object"},
    "pending_decisions": {"type": "array"},
    "basket_materialization": {"type": "object"},
    "prohibitions": {"type": "array"},
    "source_documents": {"type": "array"}
  }
}
