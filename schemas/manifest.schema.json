{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://armilar.example/schemas/data-manifest-1.0.json",
  "title": "Armilar data acquisition manifest",
  "type": "object",
  "required": ["schema_version", "generated_at", "operational_status", "summary", "entries"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "generated_at": {"type": "string"},
    "operational_status": {"enum": ["NORMAL", "DEGRADED", "FAILED"]},
    "summary": {"type": "object"},
    "entries": {"type": "array", "items": {"type": "object"}}
  },
  "additionalProperties": true
}
