    <h1 class="my-4 display-sm" data-lfr-editable-id="page-title" data-lfr-editable-type="rich-text">Household Expenditure Survey</h1>
    <p class="max-lines-2 d-none" data-lfr-editable-id="page-description" data-lfr-editable-type="rich-text">مثال النص المنسق</p>
	</div>
